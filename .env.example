FLASK_ENV=production
FLASK_DEBUG=0

DATABASE_URL=postgresql+psycopg2://blueocean:troque-por-uma-senha-forte@db:5432/blueocean

SECRET_KEY=
JWT_SECRET_KEY=
FIELD_ENCRYPTION_KEY=

MAX_CONTENT_LENGTH=10485760
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
FORCE_HTTPS=true
JWT_COOKIE_CSRF_PROTECT=true
TRUST_PROXY_HEADERS=true
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1

PLATFORM_OWNER_NAME=
PLATFORM_OWNER_USER=
PLATFORM_OWNER_PASSWORD=

# Adicione aqui as variaveis de senha de certificado fiscal configuradas no sistema.
# Exemplo de nome: SEFAZ_CERT_PASSWORD_EMPRESA_1=
